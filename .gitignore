# ================================================================
# .gitignore cho Spring Boot + Maven
# ================================================================

# ================================================================
# SECRETS — TUYỆT ĐỐI KHÔNG COMMIT
# ================================================================
application-secrets.properties
application-local.properties
*.env
.env

# ================================================================
# MAVEN BUILD OUTPUT
# ================================================================
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ================================================================
# IDE FILES
# ================================================================
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/
*.code-workspace

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ================================================================
# OS FILES
# ================================================================
.DS_Store
Thumbs.db
*.swp
*.swo

# ================================================================
# LOGS
# ================================================================
*.log
logs/

# ================================================================
# SPRING BOOT PACKAGING
# ================================================================
HELP.md
