# ================================================================
# application-secrets.properties.example
#
# ✅ File MẪU — được phép commit lên Git
# ✅ Người clone dự án copy file này, đổi tên thành:
#    application-secrets.properties
#    rồi điền thông tin thật của họ vào.
# ================================================================

# Database credentials (SQL Server Authentication)
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

# JWT Secret (Base64 encoded, ít nhất 256-bit / 32 ký tự)
# Tạo bằng: openssl rand -base64 32
jwt.secret=YOUR_BASE64_JWT_SECRET

# AWS Infrastructure IDs (tạo sẵn trên AWS Console)
# Security Group ID: vào EC2 > Security Groups để lấy
aws.ec2.securityGroupId=sg-xxxxxxxxxxxxxxxxx
# Subnet ID: vào VPC > Subnets để lấy (cần public subnet)
aws.ec2.subnetId=subnet-xxxxxxxxxxxxxxxxx
